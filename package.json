{
  "name": "@jigoooo/triphos-frontend-bootstrap",
  "version": "0.12.2",
  "description": "npx installer and dual-plugin marketplace source for Triphos frontend bootstrapping.",
  "author": "Jigoooo",
  "license": "MIT",
  "homepage": "https://github.com/Jigoooo/triphos-frontend-bootstrap",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jigoooo/triphos-frontend-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/Jigoooo/triphos-frontend-bootstrap/issues"
  },
  "keywords": [
    "triphos",
    "frontend",
    "bootstrap",
    "codex",
    "claude",
    "plugin",
    "installer"
  ],
  "type": "module",
  "bin": {
    "triphos-frontend-bootstrap": "bin/triphos-frontend-bootstrap",
    "tfb": "bin/triphos-frontend-bootstrap"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "scripts/",
    "plugins/",
    ".agents/plugins/marketplace.json",
    ".claude-plugin/marketplace.json",
    "README.md",
    "README.ko.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "install:cli": "node ./bin/triphos-frontend-bootstrap",
    "test": "node --test",
    "doctor": "node plugins/triphos-frontend-bootstrap/scripts/doctor.mjs",
    "sync:versions": "node ./scripts/sync-plugin-versions.mjs",
    "validate:structure": "node plugins/triphos-frontend-bootstrap/scripts/validate-plugin-structure.mjs",
    "check:template": "node plugins/triphos-frontend-bootstrap/scripts/check-app-constraints.mjs --target plugins/triphos-frontend-bootstrap/templates/app",
    "check:template:ssr": "node plugins/triphos-frontend-bootstrap/scripts/check-app-constraints.mjs --target plugins/triphos-frontend-bootstrap/templates/app-ssr",
    "check:parity": "node plugins/triphos-frontend-bootstrap/scripts/check-skill-parity.mjs",
    "check:bundles": "node plugins/triphos-frontend-bootstrap/scripts/check-skill-bundles.mjs",
    "check:routing": "node plugins/triphos-frontend-bootstrap/scripts/check-model-routing.mjs",
    "register:claude": "node plugins/triphos-frontend-bootstrap/scripts/register-claude-local.mjs",
    "register:codex": "node plugins/triphos-frontend-bootstrap/scripts/register-codex-local.mjs",
    "smoke:init": "node plugins/triphos-frontend-bootstrap/scripts/smoke-init.mjs",
    "smoke:init:ssr": "node plugins/triphos-frontend-bootstrap/scripts/smoke-init.mjs --template app-ssr",
    "traces:summary": "node ./scripts/traces-summary.mjs",
    "verify:repo": "pnpm run validate:structure && pnpm run check:template && pnpm run check:template:ssr && pnpm run check:parity && pnpm run check:bundles && pnpm run check:routing && pnpm test && pnpm run smoke:init && pnpm run smoke:init:ssr",
    "prepublishOnly": "pnpm run sync:versions && pnpm run verify:repo",
    "publish:dry": "npm publish --dry-run"
  }
}
